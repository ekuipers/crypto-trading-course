# CryptoPro Training — environment configuration
# Copy to ".env" (or set these in your shell/host) as needed.
# Authentication is application-only (username + password), same method as
# CryptoPro Charts and CryptoPro Suite — no third-party SSO credentials
# required.

# Port the server listens on (default 3000).
# PORT=3000

# Set to "production" to mark session cookies Secure (HTTPS only).
# NODE_ENV=production

# --- Supabase (Postgres) — accounts & sessions persistence (single sign-on) ---
# To make this project's login reuse the SAME accounts as CryptoPro Charts /
# CryptoPro Suite (one shared Supabase database across the suite, Suite
# workflow rule 18), this must resolve to the exact same Supabase Postgres
# project Charts uses. Vercel's per-project Supabase integration injects its
# own project-prefixed var names (CRYPTOPROTRAINING_POSTGRES_URL*) rather than
# a name shared with Charts, so that prefix is checked first. Tables are
# created with "create table if not exists", so pointing at the same existing
# database is a no-op on the schema.
# CRYPTOPROTRAINING_POSTGRES_URL="postgresql://...:6543/postgres?sslmode=require"
# CRYPTOPROTRAINING_POSTGRES_URL_NON_POOLING="postgresql://...:5432/postgres?sslmode=require"
# (fallbacks also accepted, checked in order: DBCRYPTOCHARTS_POSTGRES_URL[_NON_POOLING],
# POSTGRES_URL[_NON_POOLING], DATABASE_URL)

# Without a connection string the database is disabled and sign-in/register
# return 503 — the rest of the course still works (progress stays in browser
# localStorage regardless of sign-in state).
